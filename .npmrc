# React was upgraded to v19 but some deps (e.g. react-latex-next) still declare
# a peer range of react <=18. npm 7+ aborts install on that ERESOLVE conflict.
# These libs work fine on React 19 at runtime, so accept the resolution here so
# `npm install` is consistent across local dev, CI and the prod deploy server.
legacy-peer-deps=true
